        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"{{ _.login_email }}\",\n  \"senha\": \"{{ _.login_senha }}\"\n}"
      },
      "description": "Use a resposta para preencher token com accessToken e refresh_token com refreshToken no environment."
    },
    {
      "_id": "req_predicao_auth_refresh",
      "_type": "request",
      "parentId": "fld_predicao_auth",
