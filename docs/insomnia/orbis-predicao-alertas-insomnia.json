      "method": "POST",
      "url": "{{ _.base_url }}/auth/refresh",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"token\": \"{{ _.refresh_token }}\"\n}"
      },
      "description": "Gera um novo accessToken a partir do refresh_token salvo no environment."
