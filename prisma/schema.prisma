generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  TECNICO
  VISITANTE
}

enum Criticidade {
  BAIXA
  MEDIA
  ALTA
}

enum StatusSensor {
  ONLINE
  OFFLINE
  INATIVO
}

enum TipoAlerta {
  LIMITE_ULTRAPASSADO
  TENDENCIA_CURTA
  TENDENCIA_LONGA
  DEGRADACAO_ACELERADA
  INSTABILIDADE
}

enum StatusAlerta {
  ATIVO
  EM_ANDAMENTO
  RESOLVIDO
  CANCELADO
}

enum TipoEvento {
  CRIADO
  ACEITO
  ATUALIZADO
  REABERTO
  RESOLVIDO
  CANCELADO
  COMENTARIO
}

enum StatusManutencao {
  EM_ANDAMENTO
  RESOLVIDO
  ENCERRADO_SEM_SOLUCAO
}

enum FrequenciaRelatorio {
  DIARIO
  SEMANAL
  MENSAL
}

enum StatusAgendamentoRelatorio {
  ATIVO
  PAUSADO
  ERRO
}

enum TipoPeriodoRelatorio {
  RELATIVE_DAYS
  CUSTOM_RANGE
}

enum TipoExecucaoRelatorio {
  MANUAL
  AGENDADO
}

enum StatusExecucaoRelatorio {
  PROCESSANDO
  ENVIADO
  PARCIAL
  FALHOU
}

enum StatusAiActionConfirmation {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
}

// ─── MODELS ───────────────────────────────────────────────────────────────────

model Usuario {
  id            Int      @id @default(autoincrement())
  nome          String
  email         String   @unique
  senha         String
  role          Role     @default(TECNICO)
  ativo         Boolean  @default(true)
  especialidade String?
  telefone      String?
  oneSignalId   String?
  fotoPerfil    String?
  caminhoFoto   String?
  atualizadoEm  DateTime @updatedAt
  criadoEm      DateTime @default(now())

  alertas             Alerta[]
  alertaEventos       AlertaEvento[]
  manutencoes         Manutencao[]
  refreshTokens       RefreshToken[]
  passwordResetCode   PasswordResetCode?
  relatoriosAgendados RelatorioAgendamento[]
  aiActionConfirmations AiActionConfirmation[]
}

model Maquina {
  id                 Int         @id @default(autoincrement())
  nome               String
  setor              String
  tipo               String
  criticidade        Criticidade @default(BAIXA)
  ativo              Boolean     @default(true)
  integridade        Float       @default(100)
  scoreEstabilidade  Float       @default(100)
  previsaoManutencao DateTime?
  janelaManuInicio   DateTime?
  janelaManuFim      DateTime?
  imagem             String?
  caminhoImagem      String?
  criadoEm           DateTime    @default(now())

  sensores             Sensor[]
  alertas              Alerta[]
  historicoIntegridade HistoricoIntegridade[]
  manual               MaquinaManual?
}

model MaquinaManual {
  id              Int      @id @default(autoincrement())
  maquinaId       Int      @unique
  nomeArquivo     String
  mimeType        String
  tamanhoBytes    Int
  url             String
  caminho         String
  textoExtraido   String   @db.Text
  embedding       Json?
  chunks          Json?
  especificacoes  Json?
  modeloEmbedding String?
  modeloAnalise   String?
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  maquina Maquina @relation(fields: [maquinaId], references: [id], onDelete: Cascade)

  @@index([criadoEm])
}

model HistoricoIntegridade {
  id                Int      @id @default(autoincrement())
  maquinaId         Int
  integridade       Float
  scoreEstabilidade Float?
  origem            String?
  observacao        String?  @db.Text
  criadoEm          DateTime @default(now())

  maquina Maquina @relation(fields: [maquinaId], references: [id], onDelete: Cascade)

  @@index([maquinaId, criadoEm])
  @@index([criadoEm])
}

model Sensor {
  id                Int          @id @default(autoincrement())
  maquinaId         Int
  tipo              String
  status            StatusSensor @default(ONLINE)
  limiteTemperatura Float
  idealTemperatura  Float
  limiteVibracao    Float
  idealVibracao     Float
  desvioMaximoTemp  Float        @default(5.0)
  desvioMaximoVibra Float        @default(5.0)
  ultimaTemperatura Float?
  ultimaVibracao    Float?
  ultimaLeituraEm   DateTime?
  criadoEm          DateTime     @default(now())

  maquina  Maquina   @relation(fields: [maquinaId], references: [id])
  leituras Leitura[]
  alertas  Alerta[]
}

model Leitura {
  id          Int      @id @default(autoincrement())
  sensorId    Int
  temperatura Float
  vibracao    Float
  criadoEm    DateTime @default(now())

  sensor Sensor @relation(fields: [sensorId], references: [id])

  @@index([sensorId, criadoEm])
}

model Alerta {
  id           Int          @id @default(autoincrement())
  sensorId     Int
  maquinaId    Int
  tecnicoId    Int?
  tipo         TipoAlerta
  status       StatusAlerta @default(ATIVO)
  mensagem     String       @db.Text
  encerradoEm  DateTime?
  atualizadoEm DateTime     @updatedAt
  criadoEm     DateTime     @default(now())

  sensor      Sensor         @relation(fields: [sensorId], references: [id])
  maquina     Maquina        @relation(fields: [maquinaId], references: [id])
  tecnico     Usuario?       @relation(fields: [tecnicoId], references: [id])
  eventos     AlertaEvento[]
  manutencoes Manutencao[]
}

model AlertaEvento {
  id             Int           @id @default(autoincrement())
  alertaId       Int
  usuarioId      Int?
  manutencaoId   Int?
  tipo           TipoEvento
  statusAnterior StatusAlerta?
  statusNovo     StatusAlerta?
  mensagem       String?       @db.Text
  descricao      String?       @db.Text
  criadoEm       DateTime      @default(now())

  alerta     Alerta      @relation(fields: [alertaId], references: [id], onDelete: Cascade)
  usuario    Usuario?    @relation(fields: [usuarioId], references: [id])
  manutencao Manutencao? @relation(fields: [manutencaoId], references: [id])

  @@index([alertaId, criadoEm])
  @@index([usuarioId])
  @@index([manutencaoId])
}

model Manutencao {
  id         Int              @id @default(autoincrement())
  alertaId   Int
  usuarioId  Int
  observacao String           @db.Text
  status     StatusManutencao
  criadoEm   DateTime         @default(now())

  alerta  Alerta         @relation(fields: [alertaId], references: [id], onDelete: Cascade)
  usuario Usuario        @relation(fields: [usuarioId], references: [id])
  eventos AlertaEvento[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  token     String   @unique
  expiresAt DateTime
  criadoEm  DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model PasswordResetCode {
  id           String   @id @default(uuid())
  code         String
  emailDestino String
  usuarioId    Int      @unique
  expiresAt    DateTime
  criadoEm     DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("password_reset_codes")
}

model RelatorioAgendamento {
  id              Int                        @id @default(autoincrement())
  nome            String
  criadoPorId     Int
  status          StatusAgendamentoRelatorio @default(ATIVO)
  frequencia      FrequenciaRelatorio
  hora            Int
  minuto          Int                        @default(0)
  diaSemana       Int?
  diaMes          Int?
  assunto         String?
  tipoPeriodo     TipoPeriodoRelatorio
  periodo         Json
  filtros         Json
  secoes          Json?
  proximoEnvioEm  DateTime
  ultimoEnvioEm   DateTime?
  ultimoSucessoEm DateTime?
  ultimoErroEm    String?                    @db.Text
  lockedAt        DateTime?
  criadoEm        DateTime                   @default(now())
  atualizadoEm    DateTime                   @updatedAt

  criadoPor     Usuario                 @relation(fields: [criadoPorId], references: [id])
  destinatarios RelatorioDestinatario[]
  execucoes     RelatorioExecucao[]

  @@index([status, proximoEnvioEm])
}

model RelatorioDestinatario {
  id            Int      @id @default(autoincrement())
  agendamentoId Int
  email         String
  nome          String?
  criadoEm      DateTime @default(now())

  agendamento RelatorioAgendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)

  @@unique([agendamentoId, email])
  @@index([email])
}

model RelatorioExecucao {
  id              Int                     @id @default(autoincrement())
  agendamentoId   Int?
  tipoExecucao    TipoExecucaoRelatorio
  status          StatusExecucaoRelatorio @default(PROCESSANDO)
  assunto         String
  emailsDestino   Json
  periodoSnapshot Json
  filtrosSnapshot Json
  secoes          Json?
  provider        String?
  messageId       String?
  erro            String?                 @db.Text
  iniciadoEm      DateTime                @default(now())
  finalizadoEm    DateTime?

  agendamento RelatorioAgendamento? @relation(fields: [agendamentoId], references: [id], onDelete: SetNull)

  @@index([agendamentoId, iniciadoEm])
  @@index([status, iniciadoEm])
}

model AiActionConfirmation {
  id          String   @id @default(uuid())
  usuarioId   Int
  actionName  String
  actionData  Json
  actionLabel String
  summary     Json?
  status      StatusAiActionConfirmation @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, status, expiresAt])
  @@index([status, expiresAt])
}
