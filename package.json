    "seed:leituras": "node scripts/seed-leituras.js",
    "seed:visitor": "node scripts/create-visitor-user.js",
    "ci:local": "npx prisma validate && npm run test:ci && npm run test:integration",
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "simulador": "node src/simulador.js"
  },
