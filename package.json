    "test": "node --test --experimental-test-isolation=none \"tests/ci/*.test.js\" \"tests/unit/**/*.test.js\"",
    "test:coverage": "node --test --experimental-test-isolation=none --experimental-test-coverage \"tests/ci/*.test.js\" \"tests/unit/**/*.test.js\"",
    "test:ci": "npm test && npm run test:coverage",
    "test:integration": "node --test --experimental-test-isolation=none \"tests/integration/*.integration.test.js\"",
