# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# Database
DATABASE_URL="sua_url_aqui"
SUPABASE_URL="sua_url_aqui"
SUPABASE_SERVICE_ROLE="sua_url_aqui"

# IA
GROQ_API_KEY="sua_chave_groq"
GROQ_MODEL="llama-3.3-70b-versatile"
EMBEDDING_PROVIDER="gemini"
GEMINI_API_KEY="sua_chave_gemini"
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"
GEMINI_EMBEDDING_BATCH_SIZE=10
# Opcional: 768, 1536 ou 3072. Se vazio, usa o padrao do modelo.
GEMINI_EMBEDDING_DIMENSIONS=768
# Fallback legado se EMBEDDING_PROVIDER="groq".
GROQ_EMBEDDING_MODEL="nomic-embed-text-v1_5"
MANUAL_MAX_TEXT_CHARS=100000
MANUAL_CHUNK_SIZE=1800
MANUAL_CHUNK_OVERLAP=250
MANUAL_MAX_CHUNKS=80
MANUAL_ANALYSIS_CHUNKS=14

# JWT

JWT_SECRET="uma-chave-secreta-qualquer-por-agora"
JWT_EXPIRES_IN="tempo"
REFRESH_TOKEN_EXPIRES_IN_DAYS="numero_de_dias"

# Sensor

ESP32_API_KEY="chavezinha-legal"
SENSOR_OFFLINE_JOB_ENABLED=true
SENSOR_OFFLINE_INTERVAL_SECONDS=300
SIMULADOR_JOB_ATIVO=false
SIMULADOR_FORCAR_ALERTAS=false
SIMULADOR_INTERVALO_MS=5000
SIMULADOR_DEGRADACAO_HORAS=24
SIMULADOR_RUIDO_PERCENTUAL=0.01
SEED_LEITURAS_DIAS=7
SEED_LEITURAS_INTERVALO_MINUTOS=5
SEED_LEITURAS_BATCH_SIZE=1000
SEED_LEITURAS_MAX_POR_SENSOR=5000
SEED_LEITURAS_RUIDO_PERCENTUAL=0.015
SEED_LEITURAS_CRIAR_ALERTAS=false
SEED_LEITURAS_ATUALIZAR_MAQUINAS=true
SEED_LEITURAS_GARANTIR_LEITURA_ATUAL=true
SEED_INTEGRIDADE_DIAS_DEGRADACAO=30
SEED_INTEGRIDADE_INTERVALO_MINUTOS=30
SEED_INTEGRIDADE_FINAL_PERCENTUAL=70

# Performance e observabilidade
CACHE_GET_TTL_MS=5000
CACHE_DASHBOARD_TTL_MS=10000
REQUEST_SLOW_MS=1000
PRISMA_SLOW_QUERY_MS=250

# Predicao
# Reduza os minimos para testar mais rapido; aumente para exigir mais confiabilidade.
PREDICAO_MIN_PONTOS_REGRESSAO=3
PREDICAO_MIN_JANELA_REGRESSAO_HORAS=0.05
PREDICAO_MIN_INTERVALO_REGRESSAO_HORAS=0.005
PREDICAO_MAX_RAZAO_INTERVALO_REGRESSAO=60
PREDICAO_RISCO_MIN_PONTOS_HISTORICO=3
PREDICAO_RISCO_MIN_LEITURAS_24H=2
PREDICAO_RISCO_MIN_LEITURAS_72H=3
PREDICAO_RISCO_LEITURA_RECENTE_HORAS=6
PREDICAO_ALERTA_MIN_AMOSTRAS_LIMIAR=1
PREDICAO_ALERTA_LIMIAR_INSTABILIDADE=80
PREDICAO_ALERTA_LIMIAR_TENDENCIA_CURTA=85
PREDICAO_ALERTA_LIMIAR_TENDENCIA_LONGA=90

# Relatorios
# Timezone fixo do fluxo de relatorios: America/Sao_Paulo
REPORT_JOB_ENABLED=false
REPORT_JOB_CRON="* * * * *"

# Porta do servidor

PORT=40028922

# Modo de desenvolvimento ou produção

NODE_ENV="DEVELOPMENT|PRODUCTION"

# Credenciais MQTT

MQTT_URL=url_do_hiveqm
MQTT_USER=seu_usuario_do_hivemq
MQTT_PASS=sua_senha_do_hivemq
